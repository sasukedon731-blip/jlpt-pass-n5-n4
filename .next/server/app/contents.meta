{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/contents/layout,_N_T_/contents/page,_N_T_/contents"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/contents/__PAGE__",
    "/contents",
    "/_index",
    "/_head"
  ]
}