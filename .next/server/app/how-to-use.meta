{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/how-to-use/layout,_N_T_/how-to-use/page,_N_T_/how-to-use"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/how-to-use/__PAGE__",
    "/how-to-use",
    "/_index",
    "/_head"
  ]
}